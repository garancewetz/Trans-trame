# Copier ce fichier vers .env.local et renseigner les valeurs depuis le dashboard Supabase.
# Ne jamais committer de fichier contenant les vraies clés.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Google Gemini API key is now a Supabase Edge Function secret.
# Set it with: supabase secrets set GEMINI_API_KEY=your-key-here
