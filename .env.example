# Copier ce fichier vers .env.local et renseigner les valeurs depuis le dashboard Supabase.
# Ne jamais committer de fichier contenant les vraies clés.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# (Optionnel) Clé API Google Gemini pour le parsing LLM des références complexes.
# Sans cette clé, seul le parser local est utilisé.
VITE_GEMINI_API_KEY=
