{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": [
    "src/lib/**/*.ts",
    "src/domain/**/*.ts",
    "src/features/graph/domain/**/*.ts",
    "src/features/graph/api/**/*.ts"
  ]
}
