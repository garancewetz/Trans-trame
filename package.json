{
  "name": "trans-trame",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "gen-types": "supabase gen types typescript --project-id nfecgzmehlloxctfyfao > src/types/supabase.ts",
    "extract-editions": "node scripts/extract-editions.mjs --out=src/features/table/knownEditions.ts",
    "extract-authors": "node scripts/extract-authors.mjs --out=src/features/table/knownAuthors.ts",
    "extract-all": "npm run extract-editions && npm run extract-authors",
    "stress-seed": "node scripts/stress-seed.mjs",
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "typecheck:strict": "tsc -p tsconfig.strict.json --noEmit",
    "preview": "vite preview"
  },
  "dependencies": {
    "@floating-ui/react": "^0.27.19",
